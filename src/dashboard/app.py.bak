# =========================
# Supabase helpers
# =========================
def sb_query(table, select="*", filters=None, limit=2000, order=None):
    if not SUPABASE_URL or not SUPABASE_KEY:
        return pd.DataFrame()
    headers = {
        "apikey": SUPABASE_KEY,
        "Authorization": f"Bearer {SUPABASE_KEY}",
    }
    params = {"select": select, "limit": limit}
    if filters:
        params.update(filters)
    if order:
        params["order"] = order
    try:
        r = requests.get(
            f"{SUPABASE_URL}/rest/v1/{table}",
            headers=headers,
            params=params,
            timeout=20
        )
        if r.status_code == 200 and r.json():
            return pd.DataFrame(r.json())
    except Exception as e:
        st.error(f"Supabase error ({table}): {e}")
    return pd.DataFrame()

def sb_count(table, eq_filter=None):
    if not SUPABASE_URL or not SUPABASE_KEY:
        return 0
    headers = {
        "apikey": SUPABASE_KEY,
        "Authorization": f"Bearer {SUPABASE_KEY}",
        "Prefer": "count=exact",
        "Range": "0-0",
    }
    params = {}
    if eq_filter:
        for k, v in eq_filter.items():
            params[k] = f"eq.{v}"
    try:
        r = requests.get(
            f"{SUPABASE_URL}/rest/v1/{table}",
            headers=headers,
            params=params,
            timeout=10
        )
        cr = r.headers.get("Content-Range", "0/0")
        return int(cr.split("/")[-1])
    except:
        return 0

# =========================
# SQLite helpers
# =========================
@st.cache_resource
def get_sqlite():
    if os.path.exists(DB_PATH):
        conn = sqlite3.connect(DB_PATH, check_same_thread=False)
        conn.row_factory = sqlite3.Row
        return conn
    return None

def qdf(sql, params=()):
    conn = get_sqlite()
    if conn is None:
        return pd.DataFrame()
    try:
        return pd.read_sql_query(sql, conn, params=params)
    except:
        return pd.DataFrame()

def scalar(sql, params=()):
    conn = get_sqlite()
    if conn is None:
        return 0
    try:
        cur = conn.cursor()
        cur.execute(sql, params)
        row = cur.fetchone()
        return row[0] if row else 0
    except:
        return 0

# =========================
# Data cleaning functions
# =========================
def clean_papers_data(df):
    """Clean and deduplicate papers data"""
    if df.empty:
        return df
    
    # Make a copy to avoid warnings
    df_clean = df.copy()
    
    # Replace None/NaN with appropriate values
    df_clean['title'] = df_clean['title'].fillna('Untitled')
    df_clean['source'] = df_clean['source'].fillna('Unknown Source')
    df_clean['category'] = df_clean['category'].fillna('Uncategorized')
    
    # Handle URL - if None, generate a placeholder or leave as empty string
    df_clean['url'] = df_clean['url'].fillna('#')
    
    # Remove duplicates based on title (case-insensitive)
    df_clean['title_lower'] = df_clean['title'].str.lower()
    df_clean = df_clean.drop_duplicates(subset=['title_lower'], keep='first')
    df_clean = df_clean.drop(columns=['title_lower'])
    
    # Remove rows where title is just placeholder/empty
    df_clean = df_clean[~df_clean['title'].isin(['Untitled', '', 'None', 'null'])]
    
    # Sort by title for better display
    df_clean = df_clean.sort_values('title').reset_index(drop=True)
    
    return df_clean

def clean_herb_data(df):
    """Clean and deduplicate herb data"""
    if df.empty:
        return df
    
    df_clean = df.copy()
    
    # Handle missing values
    df_clean['chinese_name'] = df_clean['chinese_name'].fillna('Unknown')
    df_clean['latin_name'] = df_clean['latin_name'].fillna('Unknown')
    df_clean['taxonomy_family'] = df_clean['taxonomy_family'].fillna('Unclassified')
    df_clean['research_focus'] = df_clean['research_focus'].fillna('General')
    df_clean['data_level'] = df_clean['data_level'].fillna('preliminary')
    
    # Handle boolean fields
    df_clean['exosome_evidence'] = df_clean['exosome_evidence'].fillna(False)
    
    # Remove duplicates based on chinese_name + latin_name
    df_clean['name_key'] = df_clean['chinese_name'].str.lower() + '|' + df_clean['latin_name'].str.lower()
    df_clean = df_clean.drop_duplicates(subset=['name_key'], keep='first')
    df_clean = df_clean.drop(columns=['name_key'])
    
    return df_clean

