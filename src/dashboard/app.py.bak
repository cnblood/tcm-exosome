# =========================
# Data fixing functions
# =========================
def fix_papers_display(df):
    """修复论文显示问题"""
    if df.empty:
        return df
    
    df_fixed = df.copy()
    
    # 修复source显示
    source_fixes = {
        'Pharmacopoeia_易根': 'Pharmacopoeia_葛根',
        'Pharmacopoeia_洋羊藿': 'Pharmacopoeia_淫羊藿',
    }
    
    for wrong, correct in source_fixes.items():
        if 'source' in df_fixed.columns:
            df_fixed['source'] = df_fixed['source'].replace(wrong, correct)
    
    # 智能分类
    if 'title' in df_fixed.columns and 'category' in df_fixed.columns:
        categories = {
            'exosome': 'Exosome Biology',
            'nanovesicle': 'Nanovesicle Research',
            'extracellular vesicle': 'EV Research',
            'osteoclast': 'Bone Metabolism',
            'inflammation': 'Inflammation',
            'neurotransmitter': 'Neuroscience',
            'pharmacokinetics': 'Pharmacokinetics',
            'cholesterol': 'Lipid Metabolism',
            'cerebellar': 'Neuroscience',
            'mitochondrial': 'Cell Biology',
        }
        
        def get_category(title):
            if pd.isna(title):
                return 'Uncategorized'
            title_lower = str(title).lower()
            for key, cat in categories.items():
                if key in title_lower:
                    return cat
            return 'General'
        
        df_fixed['category'] = df_fixed['title'].apply(get_category)
    
    # 修复URL
    if 'url' in df_fixed.columns and 'title' in df_fixed.columns:
        import urllib.parse
        
        def get_url(row):
            if pd.notna(row.get('url')) and str(row['url']) not in ['None', 'N/A', '', '#']:
                return row['url']
            if pd.notna(row.get('title')):
                query = urllib.parse.quote(str(row['title']))
                return f"https://scholar.google.com/scholar?q={query}"
            return '#'
        
        df_fixed['url'] = df_fixed.apply(get_url, axis=1)
    
    return df_fixed


